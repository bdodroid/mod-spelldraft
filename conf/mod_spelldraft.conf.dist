########################################
# SpellDraft Module Configuration
########################################
#
# NOTE: The gameplay tuning and drafting rules (such as max level, starting gear,
# ban list, draft/prestige rules) live in Eluna Lua script files, specifically:
#     etc/modules/lua_scripts/spelldraft_config.lua
#
# The C++ module is a shim that handles class proficiencies and secondary resource bars.
# Setting SpellDraft.Enable to 0 will disable the C++ hooks, but will NOT affect
# the Eluna Lua scripting engine which does not read worldserver.conf.
#

#
#    SpellDraft.Enable
#        Description: Enable the C++ portion of the SpellDraft module.
#                     Disabling this disables custom class weapon/armor proficiencies
#                     and secondary power display behaviors.
#        Default:     1 - (Enabled)
#                     0 - (Disabled)
#

SpellDraft.Enable = 1

#
#    SpellDraft.AllowSpellsInDruidForms
#        Description: Allow casting any spell while in Druid shapeshift forms
#                     (Cat, Bear, Dire Bear, Travel, Aquatic, Tree of Life, Moonkin).
#                     Note: This handles server-side validation. A client-side DBC
#                     patch is still needed to prevent the client from graying out icons.
#        Default:     0 - (Disabled, default WotLK rules)
#                     1 - (Enabled)
#

SpellDraft.AllowSpellsInDruidForms = 0
